    GC_SKIP      => 1 << 13,
    GC_FSLSKIP   => 1 << 14,
    GC_MD5SKIP   => 1 << 15,
    GC_PHNSKIP   => 1 << 16,
    GC_PHLSKIP   => 1 << 17,
