sub external_regex_safe {
    my ($text, $file) = @_;
    return 1 unless $config{external_regex_reject_unsafe};
    return 0 if length($text) > $config{external_regex_max_length};
    my $count = 1 + ($text =~ tr/|/|/);
    return 0 if $count > $config{external_regex_max_count};
    return 0 if $text =~ /\(\?\??\{/;                    # executable Perl regex code
    return 0 if $text =~ /(?:\*|\+|\{\d+,?\})\s*\)(?:\*|\+|\{\d+,?\})/;
    return 0 if $text =~ /\([^)]*(?:\.\*|\.\+)[^)]*\)(?:\*|\+)/;
    return 1;
}

sub bad_file_names {
    return qw(bad_paths bad_cancel_paths bad_adult_paths bad_hosts bad_hosts_central
              bad_from bad_subject bad_body bad_url bad_url_central trusted_paths
              trusted_hosts trusted_from trusted_message_ids);
}
sub update_bad_file_mtimes {
    return unless $config_dir;
    for my $f (bad_file_names()) { my $p="$config_dir/$f"; $Bad_File_Mtime{$f}=(-e $p ? (stat($p))[9]||0 : 0); }
}
sub bad_files_changed {
    return 0 unless $config_dir;
    for my $f (bad_file_names()) { my $p="$config_dir/$f"; my $m=(-e $p ? (stat($p))[9]||0 : 0); return 1 if !defined($Bad_File_Mtime{$f}) || $m != $Bad_File_Mtime{$f}; }
    return 0;
}
sub maybe_reload_bad_files {
    my $mode=$config{bad_reload_mode}||'articles';
    my $reload=0;
    if (($mode eq 'mtime'||$mode eq 'both') && $now-$Last_Bad_Mtime_Check >= $config{bad_reload_interval}) {
        $Last_Bad_Mtime_Check=$now; $reload=1 if bad_files_changed();
    }
    if (($mode eq 'articles'||$mode eq 'both') && $status{accepted}>0 && $config{bad_rate_reload}>0
        && $status{accepted}%$config{bad_rate_reload}==0 && $status{accepted}>($status{bad_reloaded}||0)) {
        $status{bad_reloaded}=$status{accepted}; $reload=1;
    }
    if ($reload) { slog('N','Reloading external cleanfeed lists'); read_hashes(); }
}

sub update_config_fingerprint {
    # The fingerprint lets operators compare several transit servers without
    # copying and diffing every local file.  It includes the running release
    # identifier, cleanfeed.local, and every external bad_*/trusted_* list.
    # Failure to load Digest::SHA is non-fatal because fingerprinting is an
    # operational convenience, not part of the accept/reject decision.
    return unless eval { require Digest::SHA; 1 };

    my $sha = Digest::SHA->new(256);
    $sha->add($cleanfeed_maintenance_version);

    if ($config_dir) {
        for my $file ('cleanfeed.local', bad_file_names()) {
            my $path = "$config_dir/$file";
            next unless -f $path;

            if (open my $fh, '<', $path) {
                binmode $fh;
                $sha->addfile($fh);
                close $fh;
            }
        }
    }

    $Config_Fingerprint = 'sha256:' . $sha->hexdigest;
}

sub normalize_domain {
    my ($domain) = @_;

    # Domain comparisons are case-insensitive.  Trim accidental surrounding
    # whitespace before matching deny/trust lists.
    $domain = lc($domain || '');
    $domain =~ s/^\s+|\s+$//g;

    # IDN conversion is optional.  The module is not a mandatory dependency,
    # and conversion failure leaves the original lowercase value untouched.
    if ($config{idn_normalization}
            && eval { require Net::IDN::Encode; 1 }) {
        eval { $domain = Net::IDN::Encode::domain_to_ascii($domain); };
    }

    return $domain;
}
sub trusted_article {
    # Trust lists identify an article as eligible for selected bypasses.  They
    # do not themselves decide which checks are skipped; trusted_bypass_for_rule
    # below applies the individual trusted_bypass_* safety switches.
    return 1 if $Trusted_Paths_RE
        && ($hdr{Path} || '') =~ $Trusted_Paths_RE;

    return 1 if $Trusted_Hosts_RE
        && ((($state{posting_host} || '') =~ $Trusted_Hosts_RE)
            || (($state{peer} || '') =~ $Trusted_Hosts_RE));

    return 1 if $Trusted_From_RE
        && ($hdr{From} || '') =~ $Trusted_From_RE;

    return 1 if $Trusted_Message_IDs_RE
        && ($hdr{'Message-ID'} || '') =~ $Trusted_Message_IDs_RE;

    return 0;
}
sub trusted_bypass_for_rule {
    my ($rule) = @_;
    return 0 unless trusted_article();

    # Bypasses are deliberately granular.  The conservative defaults normally
    # exempt trusted automation only from scoring/EMP while preserving binary,
    # size, and crosspost protections.
    return $config{trusted_bypass_scoring}
        if $rule =~ /^(?:scoring|emp\.)/;
    return $config{trusted_bypass_content}
        if $rule =~ /^(?:header\.|body\.|mime\.|yenc\.|structure\.)/;
    return $config{trusted_bypass_binary}
        if $rule =~ /^(?:binary\.|policy\.binary)/;
    return $config{trusted_bypass_crosspost}
        if $rule eq 'crosspost';
    return $config{trusted_bypass_size}
        if $rule eq 'policy.size';

    return 0;
}

sub mode_result {
    my ($mode, $rule, $reason) = @_;
    return '' if !$mode || $mode eq 'off';

    # Audit records exactly the same finding that reject mode would enforce,
    # but accepts the article.  This is the mandatory safe rollout path for
    # heuristics whose real-world false-positive rate is not yet known.
    if ($mode eq 'audit') {
        $status{audited}++;
        policy_count($rule, $state{peer}, $groups[0]);
        policy_log_event('audit', $rule, $reason);
        return '';
    }

    # Pass the stable rule explicitly.  The second argument is retained as the
    # short human-readable response for compatibility with Cleanfeed's verbose
    # and non-verbose modes.
    return reject($reason, $reason, $rule) if $mode eq 'reject';
    return '';
}
sub max_line_length {
    my ($text)=@_; my $max=0; for my $line (split(/\n/,$text||'',-1)){ my $l=length($line);$max=$l if $l>$max;} return $max;
}
sub parse_yenc_fields {
    my ($line) = @_;
    my %f;
    while ($line =~ /(?:^|\s)([A-Za-z][A-Za-z0-9]*)=([^\s]+)/g) {
        $f{lc $1} = $2;
    }
    return %f;
}

sub encoding_findings {
    return () unless $config{malformed_encoding_check};
    my $scan = binary_scan_body();
    my $ct = $hdr{'Content-Type'} || '';
    my $cte = $hdr{'Content-Transfer-Encoding'} || '';
    my @findings;

    if ($ct =~ /^multipart\//i && $ct !~ /boundary\s*=/i) {
        push @findings, ['mime.multipart.boundary_missing',
            'MIME multipart declares no boundary parameter'];
    }
    if ($ct =~ /boundary\s*=\s*"?([^";\s]+)/i) {
        my $boundary = $1;
        if (index($scan, "--$boundary") < 0) {
            push @findings, ['mime.multipart.boundary_not_found',
                'MIME multipart boundary declared in header was not found in scanned body'];
        }
    }
    if ($cte =~ /^\s*base64\s*$/i
        && $scan !~ /(?:^|\n)[A-Za-z0-9+\/]{16,}={0,2}\r?$/m) {
        push @findings, ['mime.base64.payload_missing',
            'Base64 transfer encoding declared but no plausible payload was found'];
    }

    my @begin_lines = ($scan =~ /(?:^|\n)\s*(=ybegin\b[^\r\n]*)/ig);
    my @part_lines  = ($scan =~ /(?:^|\n)\s*(=ypart\b[^\r\n]*)/ig);
    my @end_lines   = ($scan =~ /(?:^|\n)\s*(=yend\b[^\r\n]*)/ig);

    if (@begin_lines && !@end_lines) {
        push @findings, ['yenc.structure.missing_end', '=ybegin found without a matching =yend'];
    }
    if (@end_lines && !@begin_lines) {
        push @findings, ['yenc.structure.missing_begin', '=yend found without a matching =ybegin'];
    }
    if (@part_lines && !@begin_lines) {
        push @findings, ['yenc.structure.orphan_part', '=ypart found without a matching =ybegin'];
    }

    if (@begin_lines) {
        my %yb = parse_yenc_fields($begin_lines[0]);
        my %ye = @end_lines ? parse_yenc_fields($end_lines[-1]) : ();
        my %yp = @part_lines ? parse_yenc_fields($part_lines[0]) : ();
        my $multipart = exists($yb{part}) || @part_lines;

        if (exists($yb{part}) && !@part_lines) {
            push @findings, ['yenc.structure.part_missing',
                'Multipart =ybegin declares part= but no =ypart line was found'];
        }
        if (exists($yb{part}) && $yb{part} !~ /^\d+$/) {
            push @findings, ['yenc.structure.invalid_part_number',
                'Multipart =ybegin has a non-numeric part value'];
        }
        if (exists($yb{total}) && exists($yb{part}) && $yb{total} =~ /^\d+$/
            && $yb{part} =~ /^\d+$/ && ($yb{part} < 1 || $yb{part} > $yb{total})) {
            push @findings, ['yenc.structure.invalid_part_number',
                "Multipart yEnc part number $yb{part} is outside total $yb{total}"];
        }

        if (@part_lines) {
            if (!defined($yp{begin}) || !defined($yp{end})
                || $yp{begin} !~ /^\d+$/ || $yp{end} !~ /^\d+$/
                || $yp{begin} < 1 || $yp{end} < $yp{begin}) {
                push @findings, ['yenc.structure.invalid_range',
                    '=ypart begin/end range is missing or invalid'];
            } elsif (defined($ye{size}) && $ye{size} =~ /^\d+$/) {
                my $expected = $yp{end} - $yp{begin} + 1;
                my $actual = $ye{size};
                my $tol = $config{yenc_size_tolerance_percent};
                if ($expected && abs($expected-$actual)*100/$expected > $tol) {
                    push @findings, ['yenc.metadata.part_size',
                        "Multipart yEnc part size differs from =ypart range ($actual/$expected)"];
                }
            }
        } elsif (!$multipart && defined($yb{size}) && defined($ye{size})
                 && $yb{size} =~ /^\d+$/ && $ye{size} =~ /^\d+$/) {
            my ($total,$actual)=($yb{size},$ye{size});
            my $tol=$config{yenc_size_tolerance_percent};
            if ($total && abs($total-$actual)*100/$total > $tol) {
                push @findings, ['yenc.metadata.single_size',
                    "Single-part yEnc =ybegin/=yend sizes differ ($total/$actual)"];
            }
        }
    }
    return @findings;
}

sub binary_byte_profile_in_scope {
    my $scope = $config{binary_byte_profile_scope} || 'policy';

    # "off" disables even the calculation.  This is preferable to leaving the
    # detector enabled with mode=off because no body scan or byte counting is
    # then performed at all.
    return 0 if $scope eq 'off';
    return 1 if $scope eq 'all';

    # The historical group classifier sets $gr{binary} only when the article is
    # acceptable as binary under the configured group rules.  Therefore the
    # text-only scope skips known binary destinations, but still examines mixed
    # crossposts where at least one destination is not binary-enabled.
    return !$gr{binary} if $scope eq 'text-only';

    # The recommended "policy" scope evaluates the fully merged global, peer,
    # and hierarchy policy.  A byte-profile finding is meaningful only when the
    # effective policy forbids binary data; otherwise a binary payload is normal
    # traffic and must never become a reject merely because mode=reject is set.
    if ($scope eq 'policy') {
        my $policy = policy_for_article();
        return defined($policy->{allow_binary}) && !$policy->{allow_binary};
    }

    # Configuration validation should make this unreachable.  Fail closed with
    # respect to diagnostics (do not scan/reject) if an unknown value slips in.
    return 0;
}

sub byte_profile_findings {
    return () unless $config{binary_byte_profile_enabled};
    return () unless binary_byte_profile_in_scope();

    # Scan only the configured prefix.  This keeps CPU usage bounded even for
    # multi-megabyte binary articles while still providing a representative
    # sample for opaque payloads that lack yEnc/MIME/uuencode markers.
    my $raw = substr($hdr{__BODY__} || '', 0,
        $config{binary_ratio_scan_bytes});
    my $raw_length = length($raw);

    # A minimum of zero means "allow tiny bodies to be inspected", not
    # "divide by zero when an article has no body".  Empty input contains no
    # byte-profile evidence and must therefore return no finding.
    return () if $raw_length == 0;
    return () if $raw_length < $config{binary_ratio_min_bytes};

    # Count ASCII control bytes that ordinary textual articles should almost
    # never contain.  High-bit UTF-8 bytes are deliberately not counted as
    # non-printable, preventing legitimate non-ASCII languages from looking
    # binary solely because they use multibyte character encodings.
    my $bad = ($raw =~ tr/\x00-\x08\x0b\x0c\x0e-\x1f\x7f//);
    my $pct = int($bad * 100 / $raw_length);

    return $pct > $config{binary_nonprintable_ratio_percent}
        ? (['binary.byte_profile',
            "Binary byte profile: nonprintable ratio ${pct}%"])
        : ();
}

sub path_sanity_findings {
    return () unless $config{path_sanity_enabled};

    my @tokens = split(/!/, $hdr{Path} || '', -1);
    my @findings;
    my %seen;

    if (@tokens > $config{path_max_hops}) {
        push @findings, [
            'path.hop_count',
            'Path contains ' . scalar(@tokens)
                . " hops (limit $config{path_max_hops})",
        ];
    }

    for my $token (@tokens) {
        push @findings, ['path.empty_token', 'Path contains an empty token']
            if $token eq '';

        if (length($token) > $config{path_max_token_bytes}) {
            push @findings, [
                'path.token_length',
                "Path token exceeds $config{path_max_token_bytes} bytes",
            ];
        }

        my $normalized = lc $token;
        $seen{$normalized}++;
        if ($token ne ''
                && $seen{$normalized} == $config{path_repeat_ceiling} + 1) {
            push @findings, [
                'path.repeated_token',
                "Path token '$token' is repeated more than "
                    . "$config{path_repeat_ceiling} times",
            ];
        }
    }
    return @findings;
}

sub rate_anomaly_findings {
    return () unless $config{anomaly_rate_enabled};

    my $bucket = int($now / $config{anomaly_window});
    my @findings;
    my @dimensions = (
        [$state{peer} || 'unknown', \%rate_peer,
            $config{anomaly_peer_articles}, 'peer', 'anomaly.peer_rate'],
        [$state{posting_host} || 'unknown', \%rate_host,
            $config{anomaly_host_articles}, 'posting host',
            'anomaly.host_rate'],
    );

    for my $dimension (@dimensions) {
        my ($key, $counter, $limit, $label, $rule) = @$dimension;
        next if !$limit || !$key || $key eq 'unknown' || $key eq '0';

        # Bound memory even when an upstream supplies many unique posting-host
        # values.  Clearing the short-lived anomaly table loses only the current
        # diagnostic window; it never changes ordinary Cleanfeed decisions.
        %$counter = ()
            if scalar(keys %$counter) > $config{anomaly_max_keys};

        my $id = "$bucket\0$key";
        $counter->{$id}++;
        if ($counter->{$id} == $limit + 1) {
            push @findings, [
                $rule,
                "Rate anomaly: $label '$key' exceeded $limit articles per "
                    . "$config{anomaly_window}-second window",
            ];
        }
    }
    return @findings;
}

sub apply_finding_set {
    my ($mode, @findings) = @_;
    for my $f (@findings) {
        my ($rule,$reason)=@$f;
        my $r=mode_result($mode,$rule,$reason);
        return $r if $r;
    }
    return '';
}

sub line_exceeds_limit {
    my ($text, $limit) = @_;
    return 0 if !$limit || !defined($text) || $text eq '';

    # index() walks the original scalar without allocating one scalar per line.
    # Return immediately on the first violation; the caller only needs a yes/no
    # answer, not the exact maximum length of the article.
    my $line_start = 0;
    while (1) {
        my $newline = index($text, "\n", $line_start);
        if ($newline < 0) {
            return length($text) - $line_start > $limit;
        }
        return 1 if $newline - $line_start > $limit;
        $line_start = $newline + 1;
    }
}

sub header_line_exceeds_limit {
    my ($limit) = @_;
    return 0 if !$limit;

    # INN normally gives unfolded header values, but local hooks and unusual
    # articles can still contain embedded newlines.  Inspect each value directly
    # instead of joining the entire header hash into a temporary large scalar.
    for my $value (values %hdr) {
        next if !defined($value);
        return 1 if line_exceeds_limit($value, $limit);
    }
    return 0;
}

sub apply_lightweight_guards {
    my $result;

    # Avoid every line-scan allocation when the guard is disabled.  Header and
    # body checks are independently guarded so setting either limit to zero has
    # a true zero-cost effect for that side of the article.
    if ($config{long_line_mode} ne 'off') {
        if ($config{max_header_line_bytes}
                && header_line_exceeds_limit(
                    $config{max_header_line_bytes})) {
            $result = mode_result(
                $config{long_line_mode},
                'structure.header_line',
                "Header line exceeds $config{max_header_line_bytes} bytes",
            );
            return $result if $result;
        }

        if ($config{max_body_line_bytes}
                && line_exceeds_limit(
                    $hdr{__BODY__} || '', $config{max_body_line_bytes})) {
            $result = mode_result(
                $config{long_line_mode},
                'structure.body_line',
                "Body line exceeds $config{max_body_line_bytes} bytes",
            );
            return $result if $result;
        }
    }

    $result = apply_finding_set(
        $config{malformed_encoding_mode}, encoding_findings());
    return $result if $result;

    $result = apply_finding_set(
        $config{binary_byte_profile_mode}, byte_profile_findings());
    return $result if $result;

    $result = apply_finding_set(
        $config{path_sanity_mode}, path_sanity_findings());
    return $result if $result;

    $result = apply_finding_set(
        $config{anomaly_mode}, rate_anomaly_findings());
    return $result if $result;

    return '';
}

sub record_top_offender {
    my ($rule) = @_;
    return unless $config{top_offenders_enabled};

    # Keep only bounded summary counters.  This avoids storing Message-IDs or
    # unbounded per-article state while still identifying noisy peers, posting
    # hosts, and first-listed groups in the status snapshot.
    for my $entry (
        [\%top_peer_reject,  $state{peer}],
        [\%top_host_reject,  $state{posting_host}],
        [\%top_group_reject, $groups[0]],
    ) {
        my ($table, $key) = @$entry;
        next unless $key;

        # Clearing at the configured ceiling is intentionally simple and cheap.
        # These are operational hints, not accounting-quality counters.
        %$table = ()
            if scalar(keys %$table) > $config{top_offenders_max_keys};
        $table->{policy_safe_key($key)}++;
    }
}
sub append_top_metrics {
    my ($lines) = @_;
    return unless $config{top_offenders_enabled};

    for my $set (
        ['top_reject_peer',  \%top_peer_reject],
        ['top_reject_host',  \%top_host_reject],
        ['top_reject_group', \%top_group_reject],
    ) {
        my ($prefix, $table) = @$set;
        my $position = 0;

        # Sort by descending count, then alphabetically for deterministic output
        # when two keys have the same count.
        for my $key (sort {
                $table->{$b} <=> $table->{$a} || $a cmp $b
            } keys %$table) {
            last if ++$position > $config{top_offenders_limit};
            push @$lines,
                "${prefix}_${position}=$key,$table->{$key}";
        }
    }
}

##############################################################################
# Peer/hierarchy policy engine and lightweight metrics
##############################################################################
sub policy_peer_identity {
    return $state{injection_host} if $state{injection_host};
    return first_path_host($hdr{Path}) if $hdr{Path};
    return 'unknown';
}

sub policy_merge {
    my ($base, $extra) = @_;
    my %merged = %{$base || {}};
    @merged{keys %$extra} = values %$extra if $extra;
    return \%merged;
}

sub policy_for_article {
    my $policy = {
        mode => $config{policy_mode} || 'audit',
        max_bytes => $config{policy_default_max_bytes} || 0,
        allow_binary => $config{policy_default_allow_binary} ? 1 : 0,
    };
    my $peer = $state{peer} || 'unknown';
    for my $pattern (sort { length($a) <=> length($b) || $a cmp $b } keys %Peer_Policies) {
        next unless $peer =~ /$pattern/;
        $policy = policy_merge($policy, $Peer_Policies{$pattern});
    }
    for my $group (@groups) {
        for my $pattern (sort { length($a) <=> length($b) || $a cmp $b } keys %Hierarchy_Policies) {
            next unless $group =~ /$pattern/;
            $policy = policy_merge($policy, $Hierarchy_Policies{$pattern});
        }
    }
    return $policy;
}

sub apply_policy_engine {
    my $policy = policy_for_article();
    my @matches;
    if ($policy->{max_bytes} && $state{article_bytes} > $policy->{max_bytes}) {
        push @matches, ['policy.size', "Article size $state{article_bytes} exceeds policy limit $policy->{max_bytes}"];
    }
    if (defined $policy->{allow_binary} && !$policy->{allow_binary}) {
        my $binary = is_binary();
        push @matches, ['policy.binary', 'Binary payload forbidden by peer/hierarchy policy'] if $binary;
    }
    return '' unless @matches;

    my $mode = $policy->{mode} || $config{policy_mode} || 'audit';
    return '' if $mode eq 'off';
    for my $match (@matches) {
        my ($rule, $reason) = @$match;
        policy_count($rule, $state{peer}, $groups[0]) if $mode ne 'reject';
        policy_log_event($mode, $rule, $reason) if $config{policy_log_matches};
    }
    if ($mode eq 'audit') {
        $status{audited}++;
        return '';
    }
    if ($mode eq 'quarantine') {
        $status{quarantined}++;
        # Logical quarantine: article is accepted but distinctly logged/counted.
        # Storage or routing decisions belong in INN feed configuration.
        return '';
    }
    return reject($matches[0][1], $matches[0][0]) if $mode eq 'reject';
    return '';
}

sub policy_reason_key {
    my ($reason) = @_;
    $reason = lc($reason || 'other');

    # Match precise structural findings before broad words such as "mime" or
    # "binary".  Ordering matters: a boundary failure is a MIME problem, but it
    # must retain its exact reason code instead of collapsing into binary.mime.
    return 'mime.multipart.boundary_missing'
        if $reason =~ /multipart.*(?:no|missing).*boundary|boundary parameter missing/;
    return 'mime.multipart.boundary_not_found'
        if $reason =~ /boundary.*(?:not found|absent from.*body)/;
    return 'mime.base64.payload_missing'
        if $reason =~ /base64.*(?:no|missing).*payload/;
    return 'yenc.structure.missing_end'
        if $reason =~ /ybegin.*without.*yend/;
    return 'yenc.structure.missing_begin'
        if $reason =~ /yend.*without.*ybegin/;
    return 'yenc.structure.orphan_part'
        if $reason =~ /ypart.*without.*ybegin/;
    return 'yenc.structure.part_missing'
        if $reason =~ /declares part=.*no.*ypart/;
    return 'yenc.structure.invalid_range'
        if $reason =~ /ypart.*(?:range|begin\/end).*(?:invalid|missing)/;
    return 'yenc.structure.invalid_part_number'
        if $reason =~ /part number|non-numeric part/;
    return 'yenc.metadata.part_size'
        if $reason =~ /multipart yenc part size/;
    return 'yenc.metadata.single_size'
        if $reason =~ /single-part yenc/;

    # Stable mappings for the historical EMP family.  These checks used to pass
    # the short string "EMP", which provided too little information and caused
    # valid rejects to be logged as rule=other.
    return 'emp.md5' if $reason =~ /\bmd5\b/;
    return 'emp.phl' if $reason =~ /\bphl\b|posting-host\/line/;
    return 'emp.phn' if $reason =~ /\bphn\b|(?:posting-host|path)\/newsgroups/;
    return 'emp.phr' if $reason =~ /\bphr\b|posting-host\/references/;
    return 'emp.fsl' if $reason =~ /\bfsl\b|from\/subject\/lines/;

    # Historical Cleanfeed rule families.  They are kept separate so an
    # administrator can distinguish a malformed header from a bot signature,
    # a site deny-list hit, a forged approval, a cancel policy decision, or an
    # ordinary crosspost limit without reading and parsing free-form prose.
    return 'header.invalid' if $reason =~ /invalid header|bad message-id|malformed article/;
    return 'site.path' if $reason =~ /bad path|bad site/;
    return 'site.host' if $reason =~ /bad host/;
    return 'header.reply_to' if $reason =~ /bad reply-to/;
    return 'header.sender' if $reason =~ /bad sender/;
    return 'header.from' if $reason =~ /bad from|banned from/;
    return 'bot.signature' if $reason =~ /bot signature|newsagent|pfm bot path/;
    return 'html.attachment' if $reason =~ /html file attachment/;
    return 'html.multipart_plain_missing' if $reason =~ /html multipart without text\/plain/;
    return 'html.multipart' if $reason =~ /html multipart/;
    return 'html.image' if $reason =~ /html image/;
    return 'html.article' if $reason =~ /html post|\bhtml\b/;
    return 'cancel.rogue' if $reason =~ /rogue cancel|cancel in forbidden|x-cancelled-by/;
    return 'cancel.user_spam' if $reason =~ /user-issued spam cancel/;
    return 'cancel.user' if $reason =~ /user-issued cancel/;
    return 'cancel.rejected_target' if $reason =~ /cancel for rejected article/;
    return 'supersedes.rogue' if $reason =~ /rogue supersedes|supersedes with .* path/;
    return 'repost.message_id' if $reason =~ /redundant repost \(id\)/;
    return 'repost.cache' if $reason =~ /redundant repost \(cache\)/;
    return 'approval.forged' if $reason =~ /forged approval/;
    return 'control.big8_source' if $reason =~ /big 8 .* wrong address/;
    return 'control.unapproved' if $reason =~ /unapproved .* message/;
    return 'control.poison_group' if $reason =~ /newgroup for poison group/;
    return 'control.obsolete' if $reason =~ /obsolete .* control/;
    return 'control.invalid' if $reason =~ /bad control message|bogus .* message|unwanted .* control/;
    return 'distribution.invalid' if $reason =~ /invalid distribution|u2 violation|bofh violation/;
    return 'distribution.hierarchy' if $reason =~ /hierarchy violation/;
    return 'crosspost.test' if $reason =~ /test groups|crossposted test/;
    return 'crosspost.topic' if $reason =~ /topic filter/;
    return 'crosspost' if $reason =~ /crosspost|too many newsgroups|adult group ecp/;
    return 'group.poison' if $reason =~ /poison newsgroup/;
    return 'tos.violation' if $reason =~ /tos violation/;

    # Broader content and policy categories are intentionally evaluated only
    # after the exact structural and EMP mappings above.
    return 'binary.yenc' if $reason =~ /yenc/;
    return 'binary.uuencode' if $reason =~ /uuenc/;
    return 'binary.base64' if $reason =~ /base64/;
    return 'binary.byte_profile' if $reason =~ /nonprintable|byte profile/;
    return 'binary.mime' if $reason =~ /mime|binary payload|misplaced binary/;
    return 'header.subject' if $reason =~ /subject/;
    return 'body.url' if $reason =~ /url/;
    return 'body.pattern' if $reason =~ /body/;
    return 'supersedes' if $reason =~ /supersedes/;
    return 'control' if $reason =~ /control|newgroup|rmgroup/;
    return 'scoring' if $reason =~ /scoring/;
    return 'message_id' if $reason =~ /message-id/;
    return 'structure.header_line' if $reason =~ /header line/;
    return 'structure.body_line' if $reason =~ /body line/;
    return 'path.hop_count' if $reason =~ /hop count|path contains .* hops/;
    return 'path.empty_token' if $reason =~ /empty token/;
    return 'path.token_length' if $reason =~ /token.*long|token exceeds/;
    return 'path.repeated_token' if $reason =~ /repeated token|token .* is repeated/;
    return 'anomaly.peer_rate' if $reason =~ /rate anomaly.*peer/;
    return 'anomaly.host_rate' if $reason =~ /rate anomaly/;
    return 'other';
}

sub policy_safe_key {
    my ($value) = @_;
    $value = lc($value || 'unknown');
    $value =~ s/[^a-z0-9_.-]+/_/g;
    return substr($value, 0, 120);
}

sub policy_count {
    my ($rule, $peer, $hierarchy) = @_;
    $rule = policy_safe_key($rule);
    $policy_rule_count{$rule}++ if $config{metrics_by_rule};
    if ($config{metrics_by_peer} && scalar(keys %policy_peer_count) < $config{policy_max_peer_counters}) {
        $policy_peer_count{policy_safe_key($peer)}++;
    }
    if ($config{metrics_by_hierarchy} && scalar(keys %policy_hierarchy_count) < $config{policy_max_hierarchy_counters}) {
        my ($root) = split(/\./, $hierarchy || 'unknown', 2);
        $policy_hierarchy_count{policy_safe_key($root)}++;
    }
}

sub policy_log_event {
    my ($action, $rule, $reason) = @_;
    my @parts = ('cleanfeed_event', "action=" . policy_safe_key($action), "rule=" . policy_safe_key($rule));
    push @parts, 'peer=' . policy_safe_key($state{peer}) if $config{policy_include_peer};
    push @parts, 'groups=' . policy_safe_key(join(',', @groups)) if $config{policy_include_groups};
    push @parts, 'message_id=' . policy_safe_key($hdr{'Message-ID'}) if $config{policy_include_message_id};
    my $safe_reason = $reason || '';
    $safe_reason =~ s/[\r\n\t]+/ /g;
    $safe_reason =~ s/\s+/ /g;
    push @parts, 'reason="' . substr($safe_reason, 0, 240) . '"' if $safe_reason ne '';
    slog('N', join(' ', @parts));
}

sub atomic_write_file {
    my ($path, $content) = @_;
    return 1 if !$path;

    require Fcntl;
    my $tmp = "$path.tmp.$$";
    my $fh;

    # O_EXCL prevents following a pre-created symlink or silently truncating an
    # attacker-controlled file.  Metric directories must still be owned by the
    # INN account and must not be writable by untrusted users.
    if (!sysopen($fh, $tmp,
            Fcntl::O_WRONLY() | Fcntl::O_CREAT() | Fcntl::O_EXCL(), 0640)) {
        slog('E', "Cannot create temporary file $tmp: $!");
        return 0;
    }

    if (!print {$fh} $content) {
        close($fh);
        unlink($tmp);
        slog('E', "Cannot write temporary file $tmp: $!");
        return 0;
    }
    if (!close($fh)) {
        unlink($tmp);
        slog('E', "Cannot close temporary file $tmp: $!");
        return 0;
    }
    if (!rename($tmp, $path)) {
        unlink($tmp);
        slog('E', "Cannot rename $tmp to $path: $!");
        return 0;
    }
    return 1;
}

sub metric_snapshot_lines {
    my @lines;
    push @lines, "cleanfeed_version=$cleanfeed_maintenance_version";
    push @lines, "generated_epoch=$now";
    push @lines, "started_epoch=$Start_Time";
    push @lines, 'uptime_seconds=' . ($now - $Start_Time);
    for my $key (qw(articles accepted rejected refused audited quarantined)) {
        push @lines, "$key=" . ($status{$key} || 0);
    }
    push @lines, "rate_articles_per_second=" . ($timer{rate} || 0);
    push @lines, "rate_accepted_per_second=" . ($timer{accept_rate} || 0);
    push @lines, "configuration_fingerprint=$Config_Fingerprint" if $Config_Fingerprint;
    append_top_metrics(\@lines);
    push @lines, "reject_rule_$_=$policy_rule_count{$_}" for sort keys %policy_rule_count;
    push @lines, "peer_$_=$policy_peer_count{$_}" for sort keys %policy_peer_count;
    push @lines, "hierarchy_$_=$policy_hierarchy_count{$_}" for sort keys %policy_hierarchy_count;
    return join("\n", @lines) . "\n";
}

sub write_metrics {
    return unless $config{metrics_enabled};
    atomic_write_file($config{metrics_status_file}, metric_snapshot_lines()) if $config{metrics_status_file};
    if ($config{metrics_csv_file} && $now - $Last_Metrics_CSV >= $config{metrics_csv_interval}) {
        my $new = !-e $config{metrics_csv_file} || -z $config{metrics_csv_file};
        my $csv;
        if (open($csv, '>>', $config{metrics_csv_file})) {
            print {$csv} "epoch,articles,accepted,rejected,refused,audited,quarantined\n" if $new;
            print {$csv} join(',', $now, map { $status{$_} || 0 } qw(articles accepted rejected refused audited quarantined)) . "\n";
            close($csv);
            $Last_Metrics_CSV = $now;
        } else { slog('E', "Cannot append $config{metrics_csv_file}: $!"); }
    }
    if ($config{metrics_syslog}) {
        slog('N', "metrics articles=" . ($status{articles}||0) . " accepted=" . ($status{accepted}||0) . " rejected=" . ($status{rejected}||0) . " audited=" . ($status{audited}||0) . " quarantined=" . ($status{quarantined}||0));
    }
}

