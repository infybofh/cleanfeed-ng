    GC_MEOW      => 1 << 21,
    GC_TOPIC1    => 1 << 22,
    GC_TOPIC2    => 1 << 23,
    GC_LOCALHIER => 1 << 24,
    GROUP_CACHE_MAX_NAME_BYTES => 255,
};

