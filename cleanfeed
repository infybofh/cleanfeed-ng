    my $fsl_entries = $FSLhistory ? $FSLhistory->count : 0;
    my $super_entries = $Suphistory ? $Suphistory->count : 0;
    my $mid_entries = $MIDhistory ? $MIDhistory->count : 0;

    my $html = <<'HTML_HEAD';
