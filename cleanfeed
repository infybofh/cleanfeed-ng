# Write an HTML statfile
sub html_escape {
    my ($value) = @_;
    $value = '' if !defined($value);
    $value =~ s/&/&amp;/g;
    $value =~ s/</&lt;/g;
    $value =~ s/>/&gt;/g;
    $value =~ s/"/&quot;/g;
    return $value;
}

sub html_table_rows {
    my ($items, $value_label) = @_;
    my $html = '';
    for my $key (sort { ($items->{$b} || 0) <=> ($items->{$a} || 0) || $a cmp $b }
            keys %$items) {
        $html .= '<tr><td><code>' . html_escape($key) . '</code></td><td>'
            . html_escape($items->{$key}) . "</td></tr>\n";
    }
    return $html || '<tr><td colspan="2"><em>No entries</em></td></tr>';
}

